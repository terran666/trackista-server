# ─────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=trackista
MYSQL_USER=trackista
MYSQL_PASSWORD=change_me_password

# ─────────────────────────────────────────────
# DB connection (used by backend & collector)
# ─────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Binance WebSocket endpoints
# ─────────────────────────────────────────────
BINANCE_SPOT_WS=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS=wss://fstream.binance.com/ws

# ─────────────────────────────────────────────
# Media output (inside container; bind-mounted from ./media)
# ─────────────────────────────────────────────
MEDIA_OUTPUT_DIR=/app/media

# ─────────────────────────────────────────────
# Telegram Delivery
# ─────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# Alert types enabled for Telegram delivery
TELEGRAM_SEND_MARKET_IMPULSE=true
TELEGRAM_SEND_MARKET_IN_PLAY=true
TELEGRAM_SEND_LEVEL_BREAKOUT_CANDIDATE=true
TELEGRAM_SEND_LEVEL_BOUNCE_CANDIDATE=true
TELEGRAM_SEND_LEVEL_APPROACHING=false
TELEGRAM_SEND_LEVEL_TOUCHED=false

# Global rate limiter — max Telegram messages per minute (prevents burst on restart)
TELEGRAM_RATE_LIMIT_PER_MIN=5

# Delivery cooldowns (seconds) — prevents duplicate Telegram messages per symbol
TELEGRAM_DELIVERY_COOLDOWN_MARKET_IMPULSE=600
TELEGRAM_DELIVERY_COOLDOWN_MARKET_IN_PLAY=600
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_BREAKOUT_CANDIDATE=300
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_BOUNCE_CANDIDATE=300
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_APPROACHING=300
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_TOUCHED=300

# Alert generation thresholds
ALERT_IMPULSE_THRESHOLD=150
ALERT_INPLAY_THRESHOLD=150
ALERT_SIGNAL_CONFIDENCE_MIN=80

# Phase 8.1 — Smart quality filtering (applied in AlertDeliveryService before send)
# Direction filter — block MIXED direction alerts
TELEGRAM_ALLOW_MIXED_DIRECTION=false

# Minimum score required per type
TELEGRAM_MIN_SCORE_MARKET_IMPULSE=250
TELEGRAM_MIN_SCORE_MARKET_IN_PLAY=150

# Minimum signal confidence required per type (0-100)
TELEGRAM_MIN_CONFIDENCE_MARKET_IMPULSE=80
TELEGRAM_MIN_CONFIDENCE_MARKET_IN_PLAY=75

# Minimum severity level required (low / medium / high / critical)
TELEGRAM_MIN_SEVERITY_MARKET_IMPULSE=high
TELEGRAM_MIN_SEVERITY_MARKET_IN_PLAY=medium
TELEGRAM_MIN_SEVERITY_LEVEL_BREAKOUT_CANDIDATE=medium
TELEGRAM_MIN_SEVERITY_LEVEL_BOUNCE_CANDIDATE=medium

# Burst protection — max alerts of a given type per time window
TELEGRAM_MAX_ALERTS_PER_WINDOW_MARKET_IMPULSE=3
TELEGRAM_WINDOW_SECONDS_MARKET_IMPULSE=60
TELEGRAM_MAX_ALERTS_PER_WINDOW_MARKET_IN_PLAY=5
TELEGRAM_WINDOW_SECONDS_MARKET_IN_PLAY=60

# ─────────────────────────────────────────────
# Phase 8.2 — Market Impulse v2 (5s price move + volume spike rule)
# ─────────────────────────────────────────────
MARKET_IMPULSE_ENABLED=true
MARKET_IMPULSE_WINDOW_SEC=5
MARKET_IMPULSE_PRICE_MOVE_PCT=2.5
MARKET_IMPULSE_VOLUME_SPIKE_RATIO=2.0
MARKET_IMPULSE_BASELINE_SEC=60
MARKET_IMPULSE_MIN_BASELINE_VOLUME=1
MARKET_IMPULSE_REQUIRE_FULL_BASELINE=true
MARKET_IMPULSE_DEBUG=false
