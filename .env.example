# ─────────────────────────────────────────────
# MySQL
# ─────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=trackista
MYSQL_USER=trackista
MYSQL_PASSWORD=change_me_password

# ─────────────────────────────────────────────
# DB connection (used by backend & collector)
# ─────────────────────────────────────────────
DB_HOST=mysql
DB_PORT=3306

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379

# ─────────────────────────────────────────────
# Backend
# ─────────────────────────────────────────────
API_PORT=3000
NODE_ENV=development

# ─────────────────────────────────────────────
# Binance WebSocket endpoints
# ─────────────────────────────────────────────
BINANCE_SPOT_WS=wss://stream.binance.com:9443/ws
BINANCE_FUTURES_WS=wss://fstream.binance.com/ws

# ─────────────────────────────────────────────
# Media output (inside container; bind-mounted from ./media)
# ─────────────────────────────────────────────
MEDIA_OUTPUT_DIR=/app/media

# ─────────────────────────────────────────────
# Telegram Delivery
# ─────────────────────────────────────────────
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_PARSE_MODE=HTML

# Alert types enabled for Telegram delivery
TELEGRAM_SEND_MARKET_IMPULSE=true
TELEGRAM_SEND_MARKET_IN_PLAY=true
TELEGRAM_SEND_LEVEL_BREAKOUT_CANDIDATE=true
TELEGRAM_SEND_LEVEL_BOUNCE_CANDIDATE=true
TELEGRAM_SEND_LEVEL_APPROACHING=false
TELEGRAM_SEND_LEVEL_TOUCHED=false

# Delivery cooldowns (seconds) — prevents duplicate Telegram messages
TELEGRAM_DELIVERY_COOLDOWN_MARKET_IMPULSE=120
TELEGRAM_DELIVERY_COOLDOWN_MARKET_IN_PLAY=180
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_BREAKOUT_CANDIDATE=180
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_BOUNCE_CANDIDATE=180
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_APPROACHING=120
TELEGRAM_DELIVERY_COOLDOWN_LEVEL_TOUCHED=120
